import pino from "pino";
<%_ if (language === "js") { _%>
import { config } from "../config/env.js";
<%_ } else { _%>
import { config } from "../config/env";
<%_ } _%>

const logger =
  config.nodeEnv === "development"
    ? pino(
        { level: "debug" },
        pino.transport({
          target: "pino-pretty",
          options: {
            colorize: true,
            ignore: "pid,hostname",
            translateTime: "SYS:standard",
          },
        }),
      )
    : pino({ level: "info" });

export { logger };


